{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bigKING67/design-craft/contracts/evaluation/cross-agent-run.schema.json",
  "title": "design-craft current cross-agent isolated run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "host",
    "host_version",
    "model",
    "model_observation",
    "reasoning_profile",
    "reasoning_observation",
    "runner_os",
    "started_at",
    "duration_seconds",
    "timeout_seconds",
    "prompt_path",
    "prompt_sha256",
    "prompt_transport",
    "output_path",
    "output_sha256",
    "skill_path",
    "skill_tree_sha256",
    "skill_install_mode",
    "workspace_kind",
    "cwd",
    "command",
    "returncode",
    "stderr_bytes",
    "stderr_sha256",
    "worktree_before_sha256",
    "worktree_after_sha256",
    "worktree_unchanged"
  ],
  "properties": {
    "schema": {"const": "design-craft.cross-agent-run.v2"},
    "host": {"enum": ["codex", "pi", "cursor", "claude"]},
    "host_version": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "model_observation": {"type": "string", "minLength": 1},
    "reasoning_profile": {"type": "string", "minLength": 1},
    "reasoning_observation": {"type": "string", "minLength": 1},
    "runner_os": {"type": "string", "minLength": 1},
    "started_at": {"type": "string", "minLength": 1},
    "duration_seconds": {"type": "number", "minimum": 0},
    "timeout_seconds": {"type": "integer", "minimum": 1},
    "prompt_path": {"const": "prompt.md"},
    "prompt_sha256": {"$ref": "#/$defs/sha256"},
    "prompt_transport": {"enum": ["stdin", "argument"]},
    "output_path": {"type": "string", "pattern": "^(codex|pi|cursor|claude)-output\\.md$"},
    "output_sha256": {"$ref": "#/$defs/sha256"},
    "skill_path": {"type": "string", "minLength": 1},
    "skill_tree_sha256": {"$ref": "#/$defs/sha256"},
    "skill_install_mode": {"const": "isolated_project_copy"},
    "workspace_kind": {"const": "repo_external_isolated_project"},
    "cwd": {"const": "$BENCHMARK_WORKSPACE"},
    "command": {"type": "string", "minLength": 1},
    "returncode": {"const": 0},
    "stderr_bytes": {"type": "integer", "minimum": 0},
    "stderr_sha256": {"$ref": "#/$defs/sha256"},
    "worktree_before_sha256": {"$ref": "#/$defs/sha256"},
    "worktree_after_sha256": {"$ref": "#/$defs/sha256"},
    "worktree_unchanged": {"const": true}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
