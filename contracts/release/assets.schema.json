{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bigKING67/design-craft/contracts/release/assets.schema.json",
  "title": "design-craft release asset manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "tag",
    "release_level",
    "source_commit",
    "verified_hosts",
    "verified_native",
    "unverified",
    "benchmark_status",
    "evidence_retention",
    "native_evidence",
    "package",
    "checksum",
    "sbom",
    "native_assets"
  ],
  "properties": {
    "schema": {"const": "design-craft.release-assets.v2"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "tag": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "release_level": {"enum": ["operational_95", "certified_100"]},
    "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "verified_hosts": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "verified_native": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "unverified": {"type": "object", "additionalProperties": {"type": "string"}},
    "benchmark_status": {"const": "passed"},
    "evidence_retention": {
      "enum": ["workflow_artifact_90_days", "self_contained_native_release_bundle"]
    },
    "native_evidence": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/nativeEvidence"}
    },
    "package": {"$ref": "#/$defs/packageAsset"},
    "checksum": {"$ref": "#/$defs/namedDigest"},
    "sbom": {"$ref": "#/$defs/namedDigest"},
    "native_assets": {
      "type": "array",
      "items": {"$ref": "#/$defs/fileAsset"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "fileAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "bytes": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "namedDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "packageAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256", "entry_count", "unpacked_bytes"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "entry_count": {"type": "integer", "minimum": 1},
        "unpacked_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "run_id", "run_attempt", "url", "event", "head_sha", "ref"],
      "properties": {
        "repository": {"type": "string", "minLength": 1},
        "run_id": {"type": "integer", "minimum": 1},
        "run_attempt": {"type": "integer", "minimum": 1},
        "url": {"type": "string", "minLength": 1},
        "event": {"enum": ["workflow_dispatch", "push"]},
        "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "ref": {"type": "string", "pattern": "^refs/"}
      }
    },
    "nativeEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "native",
        "schema",
        "evidence_path",
        "evidence_sha256",
        "source_commit",
        "platform",
        "runtime_kind",
        "contract_sha256",
        "observed_at",
        "workflow",
        "artifacts"
      ],
      "properties": {
        "native": {"type": "string", "minLength": 1},
        "schema": {"const": "design-craft.native-runtime-evidence.v3"},
        "evidence_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "evidence_sha256": {"$ref": "#/$defs/sha256"},
        "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "platform": {"enum": ["ios", "android"]},
        "runtime_kind": {
          "enum": ["ios_simulator", "android_emulator", "ios_device", "android_device"]
        },
        "contract_sha256": {"$ref": "#/$defs/sha256"},
        "observed_at": {"type": "string", "minLength": 1},
        "workflow": {"$ref": "#/$defs/workflow"},
        "artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nativeArtifact"}}
      }
    },
    "nativeArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "path", "bytes", "sha256"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "bytes": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
