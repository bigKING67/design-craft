{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bigKING67/design-craft/contracts/release/certification.schema.json",
  "title": "design-craft release certification bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "release_level",
    "tag",
    "source_commit",
    "artifact_name",
    "certification_workflow",
    "files"
  ],
  "properties": {
    "schema": {"const": "design-craft.release-certification.v1"},
    "release_level": {"enum": ["operational_95", "certified_100"]},
    "tag": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "artifact_name": {"type": "string", "minLength": 1},
    "certification_workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "run_id",
        "run_attempt",
        "workflow",
        "event",
        "head_branch",
        "head_sha"
      ],
      "properties": {
        "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "run_id": {"type": "integer", "minimum": 1},
        "run_attempt": {"type": "integer", "minimum": 1},
        "workflow": {"const": ".github/workflows/release-certify.yml"},
        "event": {"const": "workflow_dispatch"},
        "head_branch": {"const": "main"},
        "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "bytes", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "bytes": {"type": "integer", "minimum": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
